{"blockDat":{},"dynamicDat":{"dynamic_variables":[],"dynamic_myblocks":[]},"glsl":"#version 300 es\n\n//This is the default shader for the shader editor!\n//These functions are here and are written for the GLSL 3.0 specification.\n//You can revert it to GLSL 1.0 by removing the version number\n\nprecision highp float;\n// defualt precision for floats\n\n//our output for color\nout highp vec4 fragColor;\n//Base Variables\nattribute highp vec4 a_position;\nattribute highp vec4 a_color;\nattribute highp vec2 a_texCoord;\n\nvarying highp vec4 v_color;\nvarying highp vec2 v_texCoord;\n\nvarying highp float v_depth;\nuniform highp float u_timer;\nuniform highp mat4 u_transform;\n\n//Pen+ Textures\nuniform mediump vec2 u_res;\n\n//Base functions\n\n//Some missing math functions\nhighp float log10(highp float a) {\n  return log(a)/log(10.0);\n}\n\nhighp float eulernum(highp float a) {\n  return 2.718 * a;\n}\n\n//Psuedorandomness\nhighp vec4 pcg4d(highp vec4 v)\n{\n  v = v * 1664525.0 + 1013904223.0;\n  \n  v.x += v.y*v.w;\n  v.y += v.z*v.x;\n  v.z += v.x*v.y;\n  v.w += v.y*v.z;\n  \n  v.x += v.z*v.w;\n  v.y += v.y*v.x;\n  v.z += v.x*v.w;\n  v.w += v.y*v.x;\n  \n  return vec4(v);\n}\n\nhighp vec4 daveRandomRange(highp float lowR, highp float highR)\n{\n  lowp float r = (gl_FragCoord.x * 50.25313532) + (gl_FragCoord.y * 21.5453) + u_timer;\n  highp float randomizer = r*r/u_timer/5398932.234523;\n  return clamp(vec4(\n  fract(sin(mod(randomizer*(91.3458), 1440.0)) * 47453.5453),\n  fract(sin(mod(randomizer*(80.3458), 1440.0)) * 48456.5453),\n  fract(sin(mod(randomizer*(95.3458), 1440.0)) * 42457.5453),\n  fract(sin(mod(randomizer*(85.3458), 1440.0)) * 47553.5453)\n  ), lowR, highR);\n}\n\nhighp vec4 HSVToRGB(highp float hue, highp float saturation, highp float value, highp float a) {\n  highp float huePrime = mod(hue,360.0);\n  highp float c = (value/100.0) * (saturation/100.0);\n  highp float x = c * (1.0 - abs(mod(huePrime/60.0, 2.0) - 1.0));\n  highp float m = (value/100.0) - c;\n  highp float r = 0.0;\n  highp float g = 0.0;\n  highp float b = 0.0;\n  \n  if (huePrime >= 0.0 && huePrime < 60.0) {\n      r = c;\n      g = x;\n      b = 0.0;\n  } else if (huePrime >= 60.0 && huePrime < 120.0) {\n      r = x;\n      g = c;\n      b = 0.0;\n  } else if (huePrime >= 120.0 && huePrime < 180.0) {\n      r = 0.0;\n      g = c;\n      b = x;\n  } else if (huePrime >= 180.0 && huePrime < 240.0) {\n      r = 0.0;\n      g = x;\n      b = c;\n  } else if (huePrime >= 240.0 && huePrime < 300.0) {\n      r = x;\n      g = 0.0;\n      b = c;\n  } else if (huePrime >= 300.0 && huePrime < 360.0) {\n      r = c;\n      g = 0.0;\n      b = x;\n  }\n  r += m;\n  g += m;\n  b += m;\n  return vec4(r, g, b, a);\n}\n\nhighp vec4 HSVToRGB(highp vec4 colorInput) {\n  return HSVToRGB(colorInput.x, colorInput.y, colorInput.z, colorInput.w);\n}\n\nhighp vec4 RGBToHSV(highp float r, highp float g, highp float b, highp float a) {\n  //Get the brightest and darkest channels\n  highp float CMax = r;\n  if (g > CMax) { CMax = g; }\n  if (b > CMax) { CMax = b; }\n\n  highp float CMin = r;\n  if (g < CMin) { CMin = g; }\n  if (b < CMin) { CMin = b; }\n\n  highp float Delta = CMax - CMin;\n\n  highp float H = 0.0;\n\n  //Multiply and get the Hue\n  if (CMax == r) {\n      H = 60.0 * mod(((g - b) / Delta), 6.0);\n  }\n  if (CMax == g) {\n      H = 60.0 * ((b - r) / Delta + 2.0);\n  }\n  if (CMax == b) {\n      H = 60.0 * ((r - g) / Delta + 4.0);\n  }\n\n  //Set the saturation\n  highp float S = 0.0;\n  if (CMax != 0.0) {\n      S = Delta / CMax;\n  }\n    \n  return vec4(H, S * 100.0, CMax * 100.0, a);\n}\n\nhighp vec4 RGBToHSV(highp vec4 colorInput) {\n  return RGBToHSV(colorInput.x, colorInput.y, colorInput.z, colorInput.w);\n}\n\nhighp vec4 rotation(highp vec4 invec4) {\n  return vec4(\n    (invec4.y) * u_transform[1][0] + (invec4.x) * u_transform[1][1],\n    (invec4.y) * u_transform[1][1] - (invec4.x) * u_transform[1][0],\n    invec4.zw\n  );\n}\nuniform sampler2D u_skin;\n\nuniform highp float CustomTime;\n\nuniform highp float AutoShakeMag;\n\nuniform highp float AutoShakeSpeed;\n\nuniform highp float AutoShakeEvolution;\n\nuniform highp float AutoShakeSeed;\n\nuniform highp float AutoShakeAngle;\n\nuniform highp float AutoShakeSlack;\n\nuniform highp vec3 WarpPerspective_Rotation3D;\nuniform highp vec3 Rotation3D;\n\nuniform highp vec3 WarpPerspective_Position3D;\n\nuniform highp vec2 WaveAngle;\n\nuniform highp vec2 WaveDisplaceAngle;\n\nuniform highp vec2 WaveDisplace;\n\nuniform highp vec2 WaveAmplitude;\n\nuniform highp vec2 WaveFrequency;\n\nuniform highp vec2 WaveSpeed;\n\nuniform highp vec2 WavePhase;\n\nuniform highp vec2 WarpPerspective_TileMode;\n\nuniform highp vec2 WarpPerspective_Center;\n\nhighp vec4 Permute4(  highp vec4 custom_block_arg_A ) {\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n  return vec4(mod((((custom_block_arg_A * float(34)) + float(1)) * custom_block_arg_A),float(289)));\n\n}\n\nhighp float snoise3(  highp vec3 custom_block_arg_A ) {\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n  _snoiseC = vec2(vec2((float(1) / float(6)),(float(1) / float(3))));\n\n  _snoiseD = vec4(vec4(0,0.5,1,2));\n\n  _snoiseI = vec3(floor((custom_block_arg_A + dot(custom_block_arg_A, vec3((float(1) / float(3)),(float(1) / float(3)),(float(1) / float(3)))))));\n\n  _snoiseX0 = vec3(((custom_block_arg_A - _snoiseI) + dot(_snoiseI, vec3((float(1) / float(6)),(float(1) / float(6)),(float(1) / float(6))))));\n\n  _snoiseG = vec3(step(_snoiseX0.yzx, _snoiseX0.xyz));\n\n  _snoiseL = 1.0 - _snoiseG;\n  highp vec3 _snoiseI1 = min(_snoiseG.xyz, _snoiseL.zxy);\n  highp vec3 _snoiseI2 = max(_snoiseG.xyz, _snoiseL.zxy);\n  _snoiseX1 = _snoiseX0 -_snoiseI1 + _snoiseC.xxx;\n  _snoiseX2 = _snoiseX0 - _snoiseI2 + _snoiseC.yyy;\n  _snoiseX3 = _snoiseX0 - _snoiseD.yyy;\n  _snoiseI = vec3(mod(_snoiseI,float(289)));\n\n  _snoiseP = vec4(Permute4(\n      Permute4(Permute4(_snoiseI.z + vec4(0.0, _snoiseI1.z, _snoiseI2.z, 1.0))\n      + _snoiseI.y + vec4(0.0, _snoiseI1.y, _snoiseI2.y, 1.0))\n      + _snoiseI.x + vec4(0.0, _snoiseI1.x, _snoiseI2.x, 1.0)\n  ));\n\n  highp vec4 _snoiseJ = _snoiseP - 49.0 * floor(_snoiseP / 49.0);\n  highp vec4 _snoiseX_ = floor(_snoiseJ / 7.0);\n  highp vec4 _snoiseY_ = floor(_snoiseJ - 7.0 * _snoiseX_);\n\n  highp vec4 _snoiseX = (_snoiseX_ * 2.0 + 1.0) / 7.0 - 1.0;\n  highp vec4 _snoiseY = (_snoiseY_ * 2.0 + 1.0) / 7.0 - 1.0;\n\n  highp vec4 _snoiseH = 1.0 - abs(_snoiseX) - abs(_snoiseY);\n  highp vec4 _snoiseB0 = vec4(_snoiseX.xy, _snoiseY.xy);\n  highp vec4 _snoiseB1 = vec4(_snoiseX.zw, _snoiseY.zw);\n\n  highp vec4 _snoiseS0 = floor(_snoiseB0) * 2.0 + 1.0;\n  highp vec4 _snoiseS1 = floor(_snoiseB1) * 2.0 + 1.0;\n  highp vec4 _snoiseSH = vec4(0,0,0,0) - step(_snoiseH, vec4(0.0));\n\n  highp vec4 _snoiseA0 = _snoiseB0.xzyw + _snoiseS0.xzyw * _snoiseSH.xxyy;\n  highp vec4 _snoiseA1 = _snoiseB1.xzyw + _snoiseS1.xzyw * _snoiseSH.zzww;\n\n  highp vec3 _snoiseG0 = vec3(_snoiseA0.xy, _snoiseH.x);\n  highp vec3 _snoiseG1 = vec3(_snoiseA0.zw, _snoiseH.y);\n  highp vec3 _snoiseG2 = vec3(_snoiseA1.xy, _snoiseH.z);\n  highp vec3 _snoiseG3 = vec3(_snoiseA1.zw, _snoiseH.w);\n\n  highp vec4 _snoisenorm = vec4(1,1,1,1) / (vec4(\n      dot(_snoiseG0, _snoiseG0), dot(_snoiseG1, _snoiseG1),\n      dot(_snoiseG2, _snoiseG2), dot(_snoiseG3, _snoiseG3)\n  ));\n  _snoiseG0 *= _snoisenorm.x;\n  _snoiseG1 *= _snoisenorm.y;\n  _snoiseG2 *= _snoisenorm.z;\n  _snoiseG3 *= _snoisenorm.w;\n\n  vec4 _snoiseM = max(0.6 - vec4(\n      dot(_snoiseX0, _snoiseX0), dot(_snoiseX1, _snoiseX1),\n      dot(_snoiseX2, _snoiseX2), dot(_snoiseX3, _snoiseX3)\n  ), 0.0);\n  _snoiseM = _snoiseM * _snoiseM;\n  return float(42.0 * dot(_snoiseM * _snoiseM, vec4(\n      dot(_snoiseG0, _snoiseX0), dot(_snoiseG1, _snoiseX1),\n      dot(_snoiseG2, _snoiseX2), dot(_snoiseG3, _snoiseX3)\n  )));\n\n}\n\nhighp float Stepp(  highp float custom_block_arg_x ,\n  highp float custom_block_arg_y ) {\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n  if ((custom_block_arg_y < custom_block_arg_x)) {\n    return float(float(0));\n\n  }\n  else{\n    return float(float(1));\n\n  }\n}\n\nhighp vec3 Permute3(  highp vec3 custom_block_arg_A ) {\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n  return vec3(mod((((custom_block_arg_A * float(34)) + float(1)) * custom_block_arg_A),float(289)));\n\n}\n\nhighp float Permute1(  highp float custom_block_arg_A ) {\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n  return float(mod((((custom_block_arg_A * float(34)) + float(1)) * custom_block_arg_A),float(289)));\n\n}\n\nhighp float PI() {\n\n  return float((float(4) * atan(float(1))));\n\n}\n\nhighp vec2 Permute2(  highp vec2 custom_block_arg_A ) {\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n  return vec2(mod((((custom_block_arg_A * float(34)) + float(1)) * custom_block_arg_A),float(289)));\n\n}\n\nhighp float Dot(  highp vec4 custom_block_arg_A ,\n  highp vec4 custom_block_arg_B ) {\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n  return float(((custom_block_arg_A.x * custom_block_arg_B.x) + ((custom_block_arg_A.y * custom_block_arg_B.y) + ((custom_block_arg_A.z * custom_block_arg_B.z) + (custom_block_arg_A.w * custom_block_arg_B.w)))));\n\n}\n\nhighp vec2 AutoShakeUV(  highp vec2 custom_block_arg_YouVee ) {\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n  _AutoShakeTime = float(((AutoShakeEvolution - AutoShakeSpeed) + (CustomTime * AutoShakeSpeed)));\n\n  _AutoShakeAngle = float((AutoShakeAngle * PI()));\n\n  _AutoShakeS = float(sin(_AutoShakeAngle));\n\n  _AutoShakeC = float(cos(_AutoShakeAngle));\n\n  float _AutoShakeDX = snoise3(vec3( AutoShakeSeed * 54623.245, 0, _AutoShakeTime + AutoShakeSeed * 49235.3198 ));\n\n  float _AutoShakeDY = snoise3(vec3(\n      0,\n      AutoShakeSeed * 8723.5647,\n      _AutoShakeTime + 7468.329 + AutoShakeSeed * 19337.9404\n  ));\n\n  _AutoShakeDX *= AutoShakeMag;\n  _AutoShakeDY *= AutoShakeMag * AutoShakeSlack;\n\n  float _AutoShakeRX = _AutoShakeDX * _AutoShakeC - _AutoShakeDY * _AutoShakeS;\n  float _AutoShakeRY = _AutoShakeDX * _AutoShakeS + _AutoShakeDY * _AutoShakeC;\n  return vec2((custom_block_arg_YouVee + vec2(_AutoShakeRX, _AutoShakeRY)));\n\n}\n\nhighp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\n\n// 3D rotation functions\nvec3 rotateX(vec3 v, float angle) {\n    float s = sin(angle);\n    float c = cos(angle);\n    return vec3(v.x, v.y * c - v.z * s, v.y * s + v.z * c);\n}\n\nvec3 rotateY(vec3 v, float angle) {\n    float s = sin(angle);\n    float c = cos(angle);\n    return vec3(v.x * c + v.z * s, v.y, v.z * c - v.x * s);\n}\n\nvec3 rotateZ(vec3 v, float angle) {\n    float s = sin(angle);\n    float c = cos(angle);\n    return vec3(v.x * c - v.y * s, v.x * s + v.y * c, v.z);\n}\n\n// Tile coordinate handling (mirror/repeat/clamp)\nfloat tileCoord(float coord, int mode, out bool kill) {\n    kill = false;\n    if (mode == 0) return coord;                    // Clamp\n    if (mode == 1) return mod(coord-1.0, 2.0)+1.0;             // Repeat\n    if (mode == 2) {\n      if (mod(coord - 1.0, 2.0)*2.0 - 1.0 <= 1.0) {\n        return mod(coord - 1.0, 2.0)*2.0 - 1.0;\n      } else {\n        return 0.0-mod(coord - 1.0, 2.0)*2.0 - 1.0;\n      }\n    } // Mirror\n    if (mode == -1) {\n      if (coord >= 1.0) {\n        coord = 1.0;\n      }\n      if (coord <= -1.0) {\n        coord = -1.0;\n      }\n    }\n    if (mode == -2) {\n      if (abs(coord) >= 1.0) {\n        kill = true;\n      }\n      return coord;\n    }\n    return coord; // Default\n}\n\n// Main perspective warp function\nvec2 perspectiveWarp(vec2 uv, \n                     vec2 center,      // _PerspCenter\n                     float fov,        // _PerspFOV\n                     float pitch,      // _PerspPitch (X rotation)\n                     float yaw,        // _PerspYaw (Y rotation)\n                     float roll,       // _PerspRoll (Z rotation)\n                     vec3 position,    // _PerspPos (X, Y, Z)\n                     float depth,      // _PerspDepth\n                     int tileModeX,    // _TileModeX\n                     int tileModeY,  // _TileModeY\n                     out bool shouldKill) {\n    \n    // Convert UV to screen space centered (-1 to 1)\n    vec2 suv = (uv - center) * 2.0;\n    \n    // Create camera ray\n    vec3 ray = normalize(vec3(\n        suv.x * fov,\n        suv.y * fov,\n        1.0\n    ));\n    \n    // Apply camera rotation\n    ray = rotateX(ray, pitch);\n    ray = rotateY(ray, yaw);\n    ray = rotateZ(ray, roll);\n    \n    // Define plane (Z = constant plane)\n    vec3 planeNormal = vec3(0.0, 0.0, 1.0);\n    vec3 planePoint = vec3(\n        position.x,\n        position.y,\n        depth + position.z\n    );\n    \n    // Ray-plane intersection\n    float denom = dot(ray, planeNormal);\n    denom = abs(denom);  // Avoid division by zero\n    \n    float t = dot(planePoint, planeNormal) / denom;\n    vec3 hit = ray * t;\n    hit -= planePoint;\n    \n    // Apply tiling modes\n    bool killX = false, killY = false;\n    hit.x = tileCoord(hit.x, tileModeX, killX);\n    hit.y = tileCoord(hit.y, tileModeY, killY);\n    shouldKill = killX || killY;\n    \n    // Convert plane space to UV (0 to 1 range)\n    // Note: The 31415 and modulo 2 pattern creates a specific tiling\n    vec2 resultUV = (hit.xy + 31415.0) * 0.5;\n    resultUV = fract(resultUV);  // Equivalent to modulo 1\n    \n    // Alternative: 2x2 tiling pattern (from your example)\n    // resultUV = (hit.xy + 31415.0) % 2.0 * 0.5;\n    \n    return resultUV;\n}\n\n//Fragment Shader\nvoid fragment() {\n  gl_FragColor = v_color;\n  highp vec4 WaveDir = vec4(1);\nhighp vec4 WaveDispDir = vec4(1);\nhighp vec4 _snoiseD = vec4(1);\nhighp vec4 _snoiseP = vec4(1);\nhighp float _AutoShakeTime = float(1);\nhighp float _AutoShakeAngle = float(1);\nhighp float _AutoShakeS = float(1);\nhighp float _AutoShakeC = float(1);\nhighp vec3 _snoiseI = vec3(1);\nhighp vec3 _snoiseX0 = vec3(1);\nhighp vec3 _snoiseG = vec3(1);\nhighp vec3 _snoiseL = vec3(1);\nhighp vec3 _snoiseX1 = vec3(1);\nhighp vec3 _snoiseX2 = vec3(1);\nhighp vec3 _snoiseX3 = vec3(1);\nhighp vec2 UV = vec2(1);\nhighp vec2 WavePhaseAng = vec2(1);\nhighp vec2 WaveOutput = vec2(1);\nhighp vec2 _snoiseC = vec2(1);\nbool shouldKill = false;\n\nWaveDir = vec4(vec4(cos((PI() * WaveAngle.x)),sin((PI() * WaveAngle.x)),cos((PI() * WaveAngle.y)),sin((PI() * WaveAngle.y))));\n\nWaveDispDir = vec4(vec4(cos((PI() * WaveDisplaceAngle.x)),sin((PI() * WaveDisplaceAngle.x)),cos((PI() * WaveDisplaceAngle.y)),sin((PI() * WaveDisplaceAngle.y))));\n\nUV = vec2(v_texCoord);\n\nWavePhaseAng = vec2(vec2(((WavePhase.x * PI()) + ((Dot(vec4(vec3(UV,float(0)),float(0)),vec4(vec3(WaveDir.xy,float(0)),float(0))) * (WaveFrequency.x * float(3.139331252487636))) + (CustomTime * (WaveSpeed.x * PI())))),((WavePhase.y * PI()) + ((Dot(vec4(vec3(UV,float(0)),float(0)),vec4(vec3(WaveDir.zw,float(0)),float(0))) * (WaveFrequency.y * float(3.139331252487636))) + ((CustomTime * WaveSpeed.y) * PI())))));\n\nWaveOutput = vec2(vec2((sin(WavePhaseAng.x) * (WaveAmplitude.x * WaveDisplace.x)),(sin(WavePhaseAng.y) * (WaveAmplitude.y * WaveDisplace.y))));\n\nUV += (WaveDispDir.xy * WaveOutput.x);\n\nUV += (WaveDispDir.zw * WaveOutput.y);\n\nUV = vec2(AutoShakeUV(UV));\n\n// Option 1: Full parameter specification\nUV = perspectiveWarp(\n    UV,                                    // vec2 uv\n    WarpPerspective_Center,                       // vec2 center\n    0.8,                                   // float fov\n    WarpPerspective_Rotation3D.x * PI()/90.0,        // float pitch (X rotation)\n    WarpPerspective_Rotation3D.y * PI()/90.0,        // float yaw (Y rotation)\n    WarpPerspective_Rotation3D.z * PI()/90.0,        // float roll (Z rotation)\n    WarpPerspective_Position3D,                  // vec3 position (FIXED)\n    1.0,                                   // float depth\n    int(WarpPerspective_TileMode.x), // int tileModeX\n    int(WarpPerspective_TileMode.y), // int tileModeY\n    shouldKill\n);\n\n\nfragColor = vec4(texture(u_skin,UV).x,texture(u_skin,UV).y,texture(u_skin,UV).z,texture(u_skin,UV).w);\nif (shouldKill) {\n    fragColor = vec4(0.0, 0.0, 0.0, 0.0); // Transparent black\n    // OR discard; // Discard pixel entirely (more efficient)\n    return;\n}\n}//Vertex Shader\nvoid vertex() {\n  gl_Position = (rotation(a_position) + vec4(u_transform[0][2],u_transform[0][3],0,0)) * vec4(a_position.w * u_transform[0][0],a_position.w * -u_transform[0][1],1,1) - vec4(0,0,1,0);\n  v_color = a_color;\n  v_texCoord = a_texCoord;\n}","isText":true,"savedVarState":{"seperation":"0.01","u_skin":"Checkerboard","Amplitude":["0.1","0"],"Frequency":["25","25"],"Speed":["1","1"],"WaveAngle":["0.5","0"],"WaveDisplace":["1","1"],"WaveAmplitude":["0.0","0"],"WaveFrequency":["5","5"],"WaveSpeed":["1","1"],"WavePhase":["0","0"],"WaveDisplaceAngle":["0","0.5"],"CustomTime":"0","AutoShakeMag":"0","WarpPerspective_Rotation3D":["0","0","0"],"AutoShakeSpeed":"0","AutoShakeEvolution":"0","WarpPerspective_Center":["0.5","0.5"],"WarpPerspective_TileMode":["1","1"],"WarpPerspective_Position3D":["0","0",".25"],"Rotation3D":["0","0","0"]}}