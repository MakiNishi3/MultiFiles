ul.appLinks { list-style: none; }

ul.appLinks li { margin: 0px 0px 5px; padding: 0px; display: flex; gap: 5px; }

ul.appLinks li span { flex-basis: 30px; flex-shrink: 0; text-align: center; }

.pz-commandpalette { background-color: rgb(34, 34, 34); border: 1px solid rgb(37, 37, 37); border-radius: 3px; position: absolute; box-shadow: rgb(0, 0, 0) 0px 0px 15px; outline: 0px; }

.pz-commandpalette.global { left: 50%; top: 0px; max-width: 600px; width: 100%; transform: translateX(-50%); z-index: 2; }

.pz-commandlist { overflow-y: auto; max-height: 50vh; margin: 3px; user-select: none; }

.pz-commandlist > div { cursor: default; padding: 5px 7px; color: rgb(204, 204, 204); display: flex; gap: 10px; font-size: 14px; border-radius: 3px; align-items: center; }

.pz-commandlist > div div { display: flex; align-items: center; }

.pz-commandlist > div div.name { flex-grow: 1; }

.pz-commandlist > div.hasIcon div:first-child { align-self: center; width: 18px; height: 18px; }

.pz-commandlist > div.stateCheck div:first-child { border: 1px solid rgb(68, 68, 68); box-sizing: border-box; border-radius: 3px; padding: 0px 1px; background-color: rgb(26, 26, 26); }

