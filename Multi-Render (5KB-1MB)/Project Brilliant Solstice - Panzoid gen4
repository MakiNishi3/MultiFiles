.pz-commandlist > div { cursor: default; padding: 5px 7px; color: rgb(204, 204, 204); display: flex; gap: 10px; font-size: 14px; border-radius: 3px; align-items: center; }

.pz-commandlist > div div { display: flex; align-items: center; }

.pz-commandlist > div div.name { flex-grow: 1; }

.pz-commandlist > div.hasIcon div:first-child { align-self: center; width: 18px; height: 18px; }

.pz-commandlist > div.stateCheck div:first-child { border: 1px solid rgb(68, 68, 68); box-sizing: border-box; border-radius: 3px; padding: 0px 1px; background-color: rgb(26, 26, 26); }

.pz-commandlist > div.stateCheck.stateExclusive div:first-child { border-radius: 50%; padding: 0px; }

.pz-commandlist > div.hasIcon svg { width: 16px; height: 16px; fill: rgb(204, 204, 204); }

.pz-commandlist > div.stateCheck:not(.stateExclusive) svg { width: 14px; height: 14px; fill: rgb(204, 204, 204); }

.pz-commandlist > div:hover { background-color: rgb(48, 48, 48); }

.pz-commandlist > div.active.stateCheck div:first-child { border: 1px solid rgb(170, 170, 170); }

.pz-commandlist > div.active { background-color: rgb(51, 51, 51); }

.pz-keybinding-key { font-size: 12px; border: 1px solid rgb(65, 65, 65); padding: 2px 4px; border-radius: 3px; background-color: rgb(41, 41, 41); display: inline-block; }

.pz-keybinding-separator { padding: 0px 3px; font-size: 12px; }

.pz-commandinput { padding: 5px; box-sizing: border-box; width: 100%; background-color: rgb(42, 42, 42); border: 1px solid rgb(34, 34, 34); font-family: inherit; color: rgb(204, 204, 204); outline: 0px; font-size: 14px; border-radius: 3px; }

.pz-commandinput:focus { border-color: rgb(56, 70, 104); }
